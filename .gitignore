__pycache__/
*.py[cod]

# Rendered lecture pages are temporary review files.
tmp/pdfs/*.png

# Personal notes, planning, Discord records, and assistance records stay local.
/docs/
/docs/discord-messages.md
/outputs/**/discord_post.txt
/outputs/**/discord_update.txt

# Reproducible TOI-3505 calibration products are too large for normal Git.
# Keep the generated README and compact QA artifacts, but not the FITS images.
data/ground/toi3505/calibration/*.fits
data/ground/toi3505/reduced/*.fits
data/ground/toi3505/aligned/*.fits
data/ground/toi3505/plate_solved/**/*.fits
data/ground/toi3505/**/*.partial

# Public TESS files are reproducibly downloaded from MAST and can be large.
# Keep compact manifests and derived tables, but not the downloaded FITS files.
data/tess/toi3505/**/*.fits
data/tess/toi3505/**/*.fits.gz
data/tess/toi3505/**/*.zip
data/tess/toi3505/**/*.part
